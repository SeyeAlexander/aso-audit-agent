# --- LLM (optional but recommended) ----------------------------------------
# NVIDIA NIM exposes an OpenAI-compatible chat API on its free tier.
# Get a key at https://build.nvidia.com/ (free, ~1000 inference credits).
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Optional OpenAI-compatible override (OpenAI, Together, Groq, Anthropic, etc.)
# If set, takes precedence over NVIDIA_API_KEY.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# --- App Store enrichment (optional) ---------------------------------------
# Firecrawl scrapes the public App Store page to recover fields the iTunes
# Lookup API hides (subtitle, promotional text, What's New, top reviews).
# Get a key at https://firecrawl.dev/ (free, 500 scrapes/month).
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# --- Apple public endpoints (no auth) --------------------------------------
APP_STORE_LOOKUP_URL=https://itunes.apple.com/lookup
APP_STORE_SEARCH_URL=https://itunes.apple.com/search
