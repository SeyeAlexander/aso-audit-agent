# Optional but recommended for LLM-written recommendations.
# NVIDIA NIM exposes an OpenAI-compatible chat API.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Optional OpenAI-compatible fallback if you prefer another provider.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# Apple public endpoints do not require credentials.
APP_STORE_LOOKUP_URL=https://itunes.apple.com/lookup
APP_STORE_SEARCH_URL=https://itunes.apple.com/search
