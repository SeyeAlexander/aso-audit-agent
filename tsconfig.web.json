{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "noEmit": true,
    "baseUrl": "./web",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["web/src/**/*.ts", "web/src/**/*.tsx"]
}
